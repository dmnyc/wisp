<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- All relay URLs are validated as wss://; cleartext is never required. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
